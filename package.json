{
  "name": "world-cup",
  "version": "0.0.1",
  "private": true,
  "description": "world-cup",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "npm run start --workspace world-cup-backend & npm run start --workspace world-cup-frontend & npm run start --workspace world-cup-cdk & wait",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "pretest": "npm run prettier:check && npm run eslint && npm run typecheck",
    "typecheck": "tsgo -p packages/backend/tsconfig.json --noEmit && tsgo -p packages/cdk/tsconfig.json --noEmit && tsgo -p packages/frontend/tsconfig.json --noEmit",
    "prettier:check": "prettier --check \"**/*.{json,js,mjs,ts,tsx,md,mdx,css,html,yml,yaml,scss}\"",
    "prettier:fix": "prettier --write \"**/*.{json,js,mjs,ts,tsx,md,mdx,css,html,yml,yaml,scss}\"",
    "eslint": "eslint . --max-warnings=0",
    "deploy": "npm run cdk:deploy --workspace world-cup-cdk",
    "synth": "npm run cdk:synth --workspace world-cup-cdk"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kennethaasan/world-cup.git"
  },
  "author": "Kenneth Aasan",
  "bugs": {
    "url": "https://github.com/kennethaasan/world-cup/issues"
  },
  "homepage": "https://github.com/kennethaasan/world-cup#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript/native-preview": "7.0.0-dev.20260611.2",
    "@types/node": "^24.13.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.4.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
